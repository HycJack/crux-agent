# Crux Agent Chat - AI Configuration
# Copy this file to .env and fill in your API key.

# ===== API Keys (uncomment one) =====

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o)
# OPENAI_API_KEY=sk-...

# DeepSeek (cheapest)
# DEEPSEEK_API_KEY=sk-...

# Google (Gemini)
# GOOGLE_API_KEY=...

# xAI (Grok)
# XAI_API_KEY=xai-...

# Groq (fast)
# GROQ_API_KEY=gsk_...

# Mistral
# MISTRAL_API_KEY=...

# ===== Optional Settings =====

# Override model (default: auto-detect from provider)
# AI_MODEL=claude-sonnet-4-20250514

# Override base URL (for proxies or self-hosted)
# AI_BASE_URL=https://api.openai.com/v1

# Custom system prompt (optional)
# AI_SYSTEM_PROMPT=You are a helpful coding assistant.

# Max output tokens (default: 4096)
# AI_MAX_TOKENS=4096
